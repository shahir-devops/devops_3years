pipeline {
    agent any
    tools {
        maven 'maven 3.9.13'
    }
    environment {
        buildNum = "${env.BUILD_NUMBER}"
        image = "shahir5890/springjenkinsdw"
    }
    stages{
        stage("checkout_git"){
            steps{
            git credentialsId: 'git_user', url: 'https://github.com/shahir-devops/spring-boot-mongo-compose.git'
            }
        }
        stage("build"){
            steps{
                sh "mvn clean package"
            }
        }
        stage("docker_build"){
            steps{
                sh "docker build -t ${image}:${buildNum} ."
            }
        }
        stage("docker_push"){
            steps{
                withCredentials([string(credentialsId: 'docker_cred', variable: 'docker_cred')]) {
                sh "docker login -u shahir5890 -p ${docker_cred}"
                sh "docker push ${image}:${buildNum}"
                }
            }
        }
        stage("docker_run"){
            steps{
                sh "docker run -d --name mongoapp --network springapp -v mongodb:/data/db -e MONGO_INITDB_ROOT_USERNAME=sha -e MONGO_INITDB_ROOT_PASSWORD=sha@123 mongo:6"
                sh "docker run -d --name springappp --network springapp -p 9000:8080 -e MONGO_DB_HOSTNAME=mongoapp -e MONGO_DB_USERNAME=sha -e MONGO_DB_PASSWORD=sha@123 ${image}:${buildNum}"
            }
        }
    }
}