node{
    def mavenHome = tool name: 'maven 3.9.13', type: 'maven'
    def version = env.BUILD_NUMBER
    
    stage("check_out"){
        git credentialsId: 'git_user', url: 'https://github.com/shahir-devops/spring-boot-mongo-compose.git'
    }
    stage("build"){
        sh "$mavenHome/bin/mvn clean package"
    }
    stage("docker_image"){
        sh "docker build -t shahir5890/springjenkins:1.0.${version} ."
    }
    stage("docker_push"){
        withCredentials([usernamePassword(
            credentialsId: 'docker_cred', 
            passwordVariable: 'docker_pass', 
            usernameVariable: 'docker_user')]) {
                sh "echo ${docker_pass} | docker login -u ${docker_user} --password-stdin"
            sh "docker push shahir5890/springjenkins:1.0.${version} "
        }
    }
    stage("docker_run"){
        sh "docker run -d --name mongo --network springapp -v mongovol:/data/db -e MONGO_INITDB_ROOT_USERNAME=sha -e MONGO_INITDB_ROOT_PASSWORD=sha@123 mongo:6"
        sh "docker run -d --name springapp --network springapp -p 8081:8080 -e MONGO_DB_HOSTNAME=mongo -e MONGO_DB_USERNAME=sha -e MONGO_DB_PASSWORD=sha@123 shahir5890/springjenkins:1.0.${version}"
    }
}


