pipeline {
    agent any
    tools {
        maven 'maven 3.9.13'
    }
    environment {
        version = "${env.BUILD_NUMBER}"
    }
    stages{
        stage("checkout_git"){
            steps{
            git credentialsId: 'git_user', url: 'https://github.com/shahir-devops/spring-boot-mongo-compose.git'
            }
        }
        stage("build"){
            steps{
                sh "mvn clean package"
            }
        }
        stage("docker_build"){
            steps{
                sh "docker build -t shahir5890/springjenkinsdw:1.0.${version} ."
            }
        }
        stage("docker_push"){
            steps{
        withCredentials([usernamePassword(
            credentialsId: 'docker_cred', 
            passwordVariable: 'docker_pass', 
            usernameVariable: 'docker_user')]) {
                sh "echo ${docker_pass} | docker login -u ${docker_user} --password-stdin"
                sh "docker push shahir5890/springjenkinsdw:1.0.${version}
                }
            }
        }
        stage("k8s_deploy"){
            steps{
                sh "kubectl apply -f springbootjenkins.yml"
            }
        }
    }
}